{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon index.js",
    "start": "cross-env NODE_ENV=production node index.js",
    "start:dev": "cross-env NODE_ENV=development node index.js",
    "seed": "node src/utils/seedData.js",
    "install-cross-env": "npm install cross-env --save-dev",
    "db:erase-all": "node scripts/eraseAllData.js",
    "db:erase-select": "node scripts/eraseSelectedData.js",
    "db:clean": "node scripts/eraseSelectedData.js",
    "test": "cross-env NODE_ENV=test mocha tests/**/*.test.js --timeout 60000 --reporter spec",
    "test:production": "cross-env NODE_ENV=test mocha tests/production.test.js --timeout 60000 --reporter spec",
    "test:performance": "cross-env NODE_ENV=test mocha tests/performance.test.js --timeout 120000 --reporter spec",
    "test:all": "cross-env NODE_ENV=test mocha tests/**/*.test.js --timeout 120000 --reporter spec",
    "test:watch": "cross-env NODE_ENV=test mocha tests/**/*.test.js --timeout 60000 --watch",
    "test:coverage": "cross-env NODE_ENV=test nyc mocha tests/**/*.test.js --timeout 60000"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "multer": "^2.0.2",
    "nodemon": "^3.1.10",
    "pdfkit": "^0.17.2",
    "winston": "^3.18.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "chai": "^5.3.3",
    "cross-env": "^7.0.3",
    "mocha": "^10.8.2",
    "nyc": "^17.1.0",
    "supertest": "^7.2.2"
  }
}
